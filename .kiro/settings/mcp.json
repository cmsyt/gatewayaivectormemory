{
  "mcpServers": {
    "Playwright": {
      "command": "/Users/macos/Library/PhpWebStudy/env/node/bin/npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "env": {
        "PATH": "/Users/macos/Library/PhpWebStudy/env/node/bin:/usr/local/bin:/usr/bin:/bin"
      },
      "disabled": false,
      "autoApprove": [
        "browser_navigate",
        "browser_snapshot",
        "browser_click",
        "browser_type",
        "browser_screenshot",
        "browser_close",
        "browser_fill_form",
        "browser_network_requests",
        "browser_take_screenshot",
        "browser_evaluate",
        "browser_file_upload",
        "browser_handle_dialog",
        "browser_console_messages",
        "browser_run_code",
        "browser_resize",
        "browser_select_option",
        "browser_wait_for",
        "browser_hover"
      ]
    },
    "aivectormemory": {
      "command": "/opt/homebrew/opt/python@3.12/bin/python3.12",
      "args": [
        "-m",
        "aivectormemory",
        "--project-dir",
        "/Users/macos/item/gatewayaivectormemory"
      ],
      "disabled": false,
      "autoApprove": [
        "remember",
        "recall",
        "forget",
        "status",
        "track",
        "task",
        "readme",
        "auto_save"
      ]
    }
  }
}
