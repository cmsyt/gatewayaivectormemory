{
  "name": "代码修改前检查 track issue",
  "version": "1.0.0",
  "description": "Edit/Write 工具执行前，检查当前项目是否有活跃的 track issue，没有则拒绝执行",
  "when": {
    "type": "preToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "/Users/macos/item/gatewayaivectormemory/.kiro/hooks/check_track.sh"
  }
}
